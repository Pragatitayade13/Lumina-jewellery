{
  "name": "jewellery-management-system",
  "version": "1.0.0",
  "description": "Premium Jewellery Management System",
  "scripts": {
    "install-all": "npm install && npm install --prefix backend && npm install --prefix client",
    "server": "npm start --prefix backend",
    "client": "npm run dev --prefix client",
    "frontend": "vite --port 5179",
    "dev": "npx concurrently \"npm run server\" \"npm run client\" \"npm run frontend\"",
    "build": "vite build"
  },
  "dependencies": {
