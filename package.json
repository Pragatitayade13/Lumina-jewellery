    "@react-google-maps/api": "^2.20.8",
    "chart.js": "^4.5.1",
    "file-saver": "^2.0.5",
    "firebase": "^12.14.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lenis": "^1.3.23",
    "lucide-react": "^1.17.0",
    "nodemailer": "^8.0.10",
    "papaparse": "^5.5.3",
    "react": "^19.2.6",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.8",
    "react-modal": "^3.16.3",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.2",
