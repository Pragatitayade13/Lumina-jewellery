rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------------------------------------------------------
    // ROLE-BASED ACCESS CONTROL (RBAC) HELPER FUNCTIONS
    // ---------------------------------------------------------
    
    // Check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Get user document to check role
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      return getUserData().role;
    }

    function isSuperAdmin() {
      return isAuthenticated() && getRole() == 'superadmin';
    }

    function isAdmin() {
      return isAuthenticated() && (getRole() == 'admin' || isSuperAdmin());
    }

    function isManager() {
      return isAuthenticated() && (getRole() == 'manager' || isAdmin());
    }

    function isFinance() {
      return isAuthenticated() && (getRole() == 'finance' || isSuperAdmin());
    }

    function isDelivery() {
      return isAuthenticated() && (getRole() == 'delivery' || isSuperAdmin());
    }

    function isStaff() {
      return isAuthenticated() && (getRole() == 'staff' || isManager());
    }

    function isCustomer() {
      return isAuthenticated() && (getRole() == 'customer');
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ---------------------------------------------------------
    // COLLECTION RULES
    // ---------------------------------------------------------

    // 1. Users Collection (Profile Management)
    match /users/{userId} {
      // Anyone can create their initial account during signup
      allow create: if isAuthenticated() && request.auth.uid == userId;
      // Users can read/update their own profile. Managers+ can read all. SuperAdmins can manage all.
      allow read: if isOwner(userId) || isManager();
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // 2. Products Catalog
    match /products/{productId} {
      // Anyone (even unauthenticated) can view products on the storefront
      allow read: if true;
      // Only Staff and above can create/update products. Admins+ can delete.
      allow create, update: if isStaff();
      allow delete: if isAdmin();
    }

    // 3. Orders Collection
    match /orders/{orderId} {
      // Customers can read their own orders. Staff+ can read all.
      allow read: if (isAuthenticated() && resource.data.customerId == request.auth.uid) || isStaff();
      // Customers can place orders
      allow create: if isAuthenticated();
      // Only Managers+ can update/delete orders
      allow update, delete: if isManager();
    }

    // 4. Inventory Management
    match /inventory/{itemId} {
      // Staff+ can view and update inventory
      allow read, update: if isStaff();
      // Admins+ can add/remove inventory items
      allow create, delete: if isAdmin();
    }

    // 5. Finance & Transactions
    match /transactions/{transactionId} {
      // Only Finance and SuperAdmins can read/write financial data
      allow read, write: if isFinance();
    }

    // 6. Delivery Tracking
    match /deliveries/{deliveryId} {
      // Delivery partners can view and update their assigned routes
      allow read, update: if isDelivery();
      allow create, delete: if isManager();
    }

    // 7. Support Tickets
    match /supportTickets/{ticketId} {
      // Customers can read/write their own tickets
      allow create: if isAuthenticated();
      allow read: if (isAuthenticated() && resource.data.customerId == request.auth.uid) || isStaff();
      // Staff can update tickets
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // 8. Default Deny Fallback
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
