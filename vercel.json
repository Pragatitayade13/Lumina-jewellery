{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/delivery/:action",
      "destination": "/api/delivery?action=:action"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/((?!api/|assets/|favicon\\.svg|icons\\.svg|hero_video_1\\.mp4|hero_video_2\\.mp4).*)",
      "destination": "/index.html"
    }
  ]
}