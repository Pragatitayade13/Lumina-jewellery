{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/delivery/:action",
      "destination": "/api/delivery?action=:action"
    },
    {
      "source": "/api/ai/:subpath*",
      "destination": "/api/ai?path=:subpath*"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}