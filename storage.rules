rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // CMS assets (product images, banners, logos) — publicly readable, admin-only writes
    match /cms/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.role in ['admin', 'superadmin', 'super admin', 'manager'];
    }

    // Product images — publicly readable, staff+ can upload
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.role in ['admin', 'superadmin', 'super admin', 'manager', 'staff'];
    }

    // Delivery verification photos — authenticated read/write, scoped to delivery/staff roles
    match /delivery/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.role in ['delivery', 'delivery partner', 'admin', 'superadmin', 'super admin', 'manager', 'staff'];
    }

    // Customer uploads (profile photos, support attachments) — users can read/write their own files
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny — no open-access catch-all
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
